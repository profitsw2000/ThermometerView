<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/main">

    <fragment
        android:id="@+id/main"
        android:name="ru.profitsw2000.mainfragment.presentation.view.MainFragment"
        android:label="@string/bottom_nav_home_tab_text"
        tools:layout="@layout/fragment_main">

        <action
            android:id="@+id/action_main_to_sensor_info"
            app:destination="@+id/sensor_info_bottom_sheet"/>

        <action
            android:id="@+id/action_main_to_memory_control_fragment"
            app:destination="@+id/thermometer_memory_control_fragment"/>
    </fragment>

    <fragment
        android:id="@+id/table"
        android:name="ru.profitsw2000.tabletab.presentation.view.TableFragment"
        android:label="@string/bottom_nav_table_tab_text"
        tools:layout="@layout/fragment_table">

        <action
            android:id="@+id/action_table_to_filter_fragment"
            app:destination="@+id/history_list_filters_fragment"/>

        <action
            android:id="@+id/action_table_to_table_order_fragment"
            app:destination="@+id/table_order_bottom_sheet"/>

        <action
            android:id="@+id/action_table_to_date_selection_fragment"
            app:destination="@+id/date_time_period_selection_bottom_sheet"/>

    </fragment>

    <fragment
        android:id="@+id/graph"
        android:name="ru.profitsw2000.graphtab.presentation.view.GraphFragment"
        android:label="@string/bottom_nav_graph_tab_text"
        tools:layout="@layout/fragment_graph">

        <action
            android:id="@+id/action_graph_to_sensor_filter_fragment"
            app:destination="@+id/sensor_graph_selection_bottom_sheet"/>

        <action
            android:id="@+id/action_graph_to_time_frame_filter_fragment"
            app:destination="@+id/time_frame_graph_selection_bottom_sheet"/>

        <action
            android:id="@+id/action_graph_to_data_obtaining_method_filter_fragment"
            app:destination="@+id/data_obtaining_method_selection_bottom_sheet"/>

        <action
            android:id="@+id/action_graph_to_date_period_selection_filter_fragment"
            app:destination="@+id/date_period_graph_selection_bottom_sheet"/>
    </fragment>

    <dialog
        android:id="@+id/sensor_info_bottom_sheet"
        android:name="ru.profitsw2000.mainfragment.presentation.view.SensorInfoFragment"
        android:label="@string/sensor_info_bottom_sheet_title_text_view"
        tools:layout="@layout/fragment_sensor_info">
    </dialog>

    <fragment
        android:id="@+id/thermometer_memory_control_fragment"
        android:name="ru.profitsw2000.memoryfragment.presentation.view.MemoryFragment"
        android:label="@string/thermometer_memory_fragment_label_text"
        tools:layout="@layout/fragment_memory">
    </fragment>

    <fragment
        android:id="@+id/history_list_filters_fragment"
        android:name="ru.profitsw2000.tabletab.presentation.view.HistoryTableFilterFragment"
        android:label="@string/sort_history_list_fragment_label_text"
        tools:layout="@layout/fragment_history_table_filter">

        <action
            android:id="@+id/history_list_filters_to_all_filter_items"
            app:destination="@+id/all_filter_items_fragment"/>
    </fragment>

    <fragment
        android:id="@+id/all_filter_items_fragment"
        android:name="ru.profitsw2000.tabletab.presentation.view.AllFilterItemsFragment"
        tools:layout="@layout/fragment_all_filter_items">
    </fragment>

    <dialog
        android:id="@+id/table_order_bottom_sheet"
        android:name="ru.profitsw2000.tabletab.presentation.view.TableOrderBottomSheetFragment"
        tools:layout="@layout/fragment_table_order_bottom_sheet">
    </dialog>

    <dialog
        android:id="@+id/date_time_period_selection_bottom_sheet"
        android:name="ru.profitsw2000.tabletab.presentation.view.DateTimePeriodSelectionBottomSheetFragment"
        tools:layout="@layout/fragment_date_time_period_selection_bottom_sheet">
    </dialog>

    <dialog
        android:id="@+id/sensor_graph_selection_bottom_sheet"
        android:name="ru.profitsw2000.graphtab.presentation.view.SensorFilterBottomSheetFragment"
        tools:layout="@layout/fragment_sensor_filter_bottom_sheet_dialog">
    </dialog>

    <dialog
        android:id="@+id/time_frame_graph_selection_bottom_sheet"
        android:name="ru.profitsw2000.graphtab.presentation.view.TimeFrameFilterBottomSheetFragment"
        tools:layout="@layout/fragment_time_frame_filter_bottom_sheet">
    </dialog>

    <dialog
        android:id="@+id/data_obtaining_method_selection_bottom_sheet"
        android:name="ru.profitsw2000.graphtab.presentation.view.DataObtainingMethodSelectionFragment"
        tools:layout="@layout/fragment_data_obtaining_method_selection">
    </dialog>

    <dialog
        android:id="@+id/date_period_graph_selection_bottom_sheet"
        android:name="ru.profitsw2000.graphtab.presentation.view.DateSelectionBottomSheetFragment"
        tools:layout="@layout/fragment_date_selection_bottom_sheet">
    </dialog>

</navigation>